auth_enabled: {{ loki_auth_enabled | bool | lower }}

server:
  http_listen_address: {{ loki_http_listen_address }}
  http_listen_port: {{ loki_http_listen_port }}
  log_level: {{ loki_log_level }}

common:
  path_prefix: {{ loki_data_dir }}
  replication_factor: {{ loki_replication_factor }}
  ring:
    kvstore:
      store: inmemory

schema_config:
  configs:
    - from: "{{ loki_schema_from }}"
      store: {{ loki_schema_store }}
      object_store: {{ loki_schema_object_store }}
      schema: {{ loki_schema_version }}
      index:
        prefix: index_
        period: 24h

storage_config:
  filesystem:
    directory: {{ loki_chunks_dir }}

ingester:
  wal:
    enabled: true
    dir: {{ loki_wal_dir }}

limits_config:
  retention_period: {{ loki_retention_period }}
  allow_structured_metadata: true
  volume_enabled: true
  ingestion_rate_mb: 8
  ingestion_burst_size_mb: 16

compactor:
  working_directory: {{ loki_compactor_dir }}
  compaction_interval: 10m
  retention_enabled: true
  delete_request_store: filesystem

query_range:
  cache_results: {{ loki_query_range_results_cache_enabled | bool | lower }}

ruler:
  storage:
    type: local
    local:
      directory: {{ loki_rules_dir }}
  rule_path: {{ loki_rules_dir }}

